#cloud-config
users:
  - name: fortress
    groups: [sudo, netdev, video, input]
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: true
    ssh_authorized_keys:
      - YOUR_SSH_PUBLIC_KEY_HERE

write_files:
  - path: /etc/apt/sources.list.d/debian.sources
    content: |
      Types: deb
      URIs: https://deb.debian.org/debian/
      Suites: trixie trixie-updates
      Components: main contrib non-free non-free-firmware
      Signed-By: /usr/share/keyrings/debian-archive-keyring.pgp

      Types: deb
      URIs: https://deb.debian.org/debian-security/
      Suites: trixie-security
      Components: main contrib non-free non-free-firmware
      Signed-By: /usr/share/keyrings/debian-archive-keyring.pgp

  - path: /etc/apt/sources.list.d/raspi.sources
    content: |
      Types: deb
      URIs: https://archive.raspberrypi.com/debian/
      Suites: trixie
      Components: main
      Signed-By: /usr/share/keyrings/raspberrypi-archive-keyring.pgp

  - path: /etc/chrony/sources.d/bootstrap-nts.sources
    content: |
      pool time.cloudflare.com iburst nts
      pool nts.netnod.se iburst nts

  - path: /etc/profile.d/fortress-nag.sh
    permissions: '0755'
    content: |
      #!/bin/bash
      FLAG_FILE="/var/lib/system-provisioned.flag"
      INIT_SCRIPT="/usr/local/bin/fortress-init.sh"

      if [ ! -f "$FLAG_FILE" ]; then
          echo -e "\n\e[1;31m!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!\e[0m"
          echo -e "\e[1;37;41m       WARNING: FORTRESS IS UNFINISHED!         \e[0m"
          echo -e "\e[1;31m!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!\e[0m"
          echo -e "\n\e[1;33mThe scaffolding is still up and the decor is pants.\e[0m"
          echo -e "To sort this shambles, run the manual bootstrap now:"
          echo -e "\n\e[1;32m   sudo $INIT_SCRIPT \e[0m\n"
          echo -e "\e[1;31m!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!\e[0m\n"
      fi

  - path: /usr/local/bin/fortress-init.sh
    permissions: '0755'
    content: |
      #!/bin/bash
      LOG_FILE="/tmp/fortress-provision.log"
      FLAG_FILE="/var/lib/system-provisioned.flag"
      SESSION_NAME="fortress_decor"

      if [[ $EUID -ne 0 ]]; then
         echo -e "\e[1;31m[!] ERROR: This script must be run with sudo.\e[0m" 
         exit 1
      fi

      if [ -f "$FLAG_FILE" ]; then
          echo "System Provisioned, Ignoring."
          exit 0
      fi

      until ping -c 1 1.1.1.1; do sleep 5; done

      # 2. Fix the 'stale index' and get the tools
      DEBIAN_FRONTEND=noninteractive apt update -y
      DEBIAN_FRONTEND=noninteractive apt upgrade -y

      apt install -y git chrony ansible tmux

      sed -i 's/^pool [0-9].debian.pool.ntp.org iburst/# &/' /etc/chrony/chrony.conf

      systemctl restart chronyd

      tmux has-session -t "$SESSION_NAME" 2>/dev/null
      if [ $? -eq 0 ]; then
          echo "Script is already running ina tmux session"
          exit 0
      fi

      tmux new-session -d -s "$SESSION_NAME" " ( \
          ansible-pull -U 'https://github.com/jm1666/guardians-of-digital-dignity.git' provision.yaml && \
          touch $FLAG_FILE && \
          echo '--- Renovations Complete: Flag Planted ---' \
      ) 2>&1 | tee -a $LOG_FILE; bash"
      
      echo "Crew is in the tmux lounge. To peek at the decor: sudo tmux attach -t $SESSION_NAME"

timezone: Etc/UTC
manage_resolv_conf: false
keyboard:
  model: pc105
  layout: "us"
enable_ssh: true
ssh_pwauth: false
