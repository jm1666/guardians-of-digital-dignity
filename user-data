#cloud-config
users:
  - name: fortress
    groups: [sudo, video, input]
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: true
    ssh_authorized_keys:
      - YOUR_SSH_PUBLIC_KEY_HERE

manage_resolv_conf: false
timezone: #TODO
keyboard:
  model: pc105
  layout: "us"
enable_ssh: true
ssh_pwauth: false
package_update: true

rpi:
  interfaces:
    serial: true
    i2c: true

ansible:
  install_method: distro
  package_name: ansible
  pull:
    url: "https://github.com/jm1666/guardians-of-digital-dignity.git"
    playbook_name: "provision.yml"


