#cloud-config
users:
  - name: fortress
    groups: [sudo, video, input]
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: true
    ssh_authorized_keys:
      - YOUR_SSH_PUBLIC_KEY_HERE

manage_resolv_conf: false
timezone: #TODO
keyboard:
  model: pc105
  layout: "us"
enable_ssh: true
ssh_pwauth: false

rpi:
  interfaces:
    serial: true
    i2c: true

# 1. THE GUARDIAN (Written immediately)
write_files:
  - path: /usr/local/bin/post-install.sh
    owner: root:root
    permissions: '0755'
    content: |
      #!/bin/bash
      echo "--- FORTRESS STATUS REPORT ---"
      if [ -f /home/fortress/FORTRESS_RECOVERY.txt ]; then
          echo "[!] RECOVERY SECRETS FOUND. SECURE THEM AND DELETE THE FILE."
          cat /home/fortress/FORTRESS_RECOVERY.txt
      fi

packages:
  - git
  - ansible
  - firewalld
  - network-manager

# 2. NATIVE ANSIBLE TRIGGER (Zero-Interaction)
ansible:
  install_method: distro
  package_name: ansible
  pull:
    url: "https://github.com/jm1666/guardians-of-digital-dignity.git"
    playbook_name: "provision.yml"

runcmd:
  - [ /usr/local/bin/post-install.sh ]
  - [ rfkill, unblock, wifi ]
  - [ sh, -c, "for f in /var/lib/systemd/rfkill/*:wlan; do echo 0 > \"$f\"; done" ]

