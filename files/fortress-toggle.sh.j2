#!/bin/bash

if [[ $EUID -ne 0 ]]; then
   echo -e "\e[1;31m[!] ERROR: This script must be run with sudo.\e[0m" 
   exit 1
fi

MODE=$1
ETH="{{ ansible_default_ipv4.interface }}"
WLAN_WAN="{{ secondary_wifi_interface }}"
EXIT_NODE=$2
MODE_FILE="/var/lib/fortress_mode"

case $MODE in
  maint)
    echo -e "\e[1;34m[-] Switching to Maintenance MODE...\e[0m"
    /usr/bin/firewall-cmd --zone=trusted --change-interface=$ETH
    tailscale up --reset --exit-node= || exit 1
    echo -e "\e[1;33m[!] WARNING: Changes are RUNTIME ONLY. Reboot will Seal the Fortress.\e[0m"
    ;;

  lean)
    echo -e "\e[1;33m[|] Switching to LEAN MODE (Scout/DNS Only)...\e[0m"
    /usr/bin/firewall-cmd --permanent --zone=public --change-interface=$ETH
    /usr/bin/firewall-cmd --permanent --zone=public --change-interface=$WLAN_WAN
    /usr/bin/firewall-cmd --permanent --policy hotspotToPub --set-target ACCEPT
    /usr/bin/firewall-cmd --permanent --policy hotspotToVPN --set-target REJECT
    tailscale up --reset --accept-routes=true || exit 1
    /usr/bin/firewall-cmd --reload
    echo "LEAN" > "$MODE_FILE"
    echo -e "\e[1;32m[✓] Lean Mode: $ETH/$WLAN_WAN are DROP. Forwarding REJECTED.\e[0m"
    ;;

  secure)
    echo -e "\e[1;31m[!] Switching to SECURE MODE (VPN)...\e[0m"
    /usr/bin/firewall-cmd --permanent --zone=public --change-interface=$ETH
    /usr/bin/firewall-cmd --permanent --zone=public --change-interface=$WLAN_WAN
    /usr/bin/firewall-cmd --permanent --policy hotspotToPub --set-target REJECT
    /usr/bin/firewall-cmd --permanent --policy hotspotToVPN --set-target ACCEPT
    tailscale up --reset --exit-node=$2 --exit-node-allow-lan-access=true --accept-routes=true || exit 1
    /usr/bin/firewall-cmd --reload
    echo "SECURE" > "$MODE_FILE"
    echo -e "\e[1;32m[✓] Secure Mode: Tunneling through $EXIT_NODE.\e[0m"
    ;;

  *)
    echo "Usage: sudo fortress-mode [maint|lean|secure]"
    ;;
esac
